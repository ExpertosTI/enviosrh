# ── enviosrh — Dockerfile frontend (PWA) ─────────────────────
# Build con Vite, sirve estáticos con nginx:alpine.

FROM node:22-alpine AS build
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
COPY . .
ARG VITE_API_URL
ENV VITE_API_URL=${VITE_API_URL}
RUN npm run build

FROM nginx:1.27-alpine
LABEL org.opencontainers.image.title="enviosrh-web"

RUN rm -rf /etc/nginx/conf.d/default.conf /usr/share/nginx/html/*

COPY nginx.conf /etc/nginx/conf.d/enviosrh.conf
COPY --from=build /app/dist /usr/share/nginx/html
RUN printf 'ok\n' > /usr/share/nginx/html/healthz

EXPOSE 80
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD wget -q -O /dev/null http://127.0.0.1/healthz || exit 1
