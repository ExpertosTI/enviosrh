# ── enviosrh — Variables de entorno ──────────────────────────
# Copia este archivo como .env en el servidor y ajusta cada valor

# Dominio público donde corre la app
DOMAIN=tu-dominio.com

# Base de datos (Postgres interno del stack)
POSTGRES_DB=enviosrh
POSTGRES_USER=enviosrh
POSTGRES_PASSWORD=genera_una_contrasena_segura_aqui

# JWT: mínimo 32 caracteres aleatorios (usa: openssl rand -hex 32)
JWT_SECRET=reemplaza_con_openssl_rand_hex_32

# Admin inicial (se crea al primer arranque si no existe ningún operador)
ADMIN_EMAIL=admin@tu-dominio.com
ADMIN_PASSWORD=cambia_esto_despues_del_primer_login

# URL pública de la app (sin / al final)
VITE_API_URL=https://tu-dominio.com/api

# Empresa / branding (aparece en mensajes de WhatsApp)
COMPANY_NAME=
COMPANY_PHONE=
