# ── enviosrh — Variables de entorno ──────────────────────────
# Copia a .env en el servidor y ajusta los valores

# Dominio
DOMAIN=enviosrh.renace.tech

# Base de datos (Postgres interno del stack)
POSTGRES_DB=enviosrh
POSTGRES_USER=enviosrh_user
POSTGRES_PASSWORD=cambia_esta_contrasena_segura

# JWT para autenticación de mensajeros y operadores
JWT_SECRET=cambia_este_secreto_de_al_menos_32_chars

# URL interna de la API (usada por el frontend en build)
VITE_API_URL=https://enviosrh.renace.tech/api

# Empresa / branding (aparece en mensajes de WhatsApp)
COMPANY_NAME=Altamar
COMPANY_PHONE=8091234567
